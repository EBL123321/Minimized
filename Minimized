-- Minimizar lógica
local function updateUI()
    if minimized then
        fr.Size=UDim2.new(0,200,0,35)
        tb.Visible=false
        spf.Visible=false
        nb.Visible=false
        minBtn.Text="+"
    else
        fr.Size=UDim2.new(0,250,0,200)
        tb.Visible=true
        spf.Visible=true
        nb.Visible=true
        minBtn.Text="-"
    end
end

minBtn.MouseButton1Click:Connect(function()
    minimized=not minimized
    updateUI()
end)

tb.MouseButton1Click:Connect(function()
    f=not f
    if f then
        sf()
        tb.Text="DISABLE FLY"
        tb.BackgroundColor3=Color3.fromRGB(170,0,0)
    else
        stop()
        tb.Text="ENABLE FLY"
        tb.BackgroundColor3=Color3.fromRGB(0,170,0)
    end
end)

up.MouseButton1Click:Connect(function()
    s=math.min(s+1,500)
    sl.Text="Speed: "..s
end)

dn.MouseButton1Click:Connect(function()
    s=math.max(s-1,1)
    sl.Text="Speed: "..s
end)

nb.MouseButton1Click:Connect(function()
    noclip=not noclip
    setNoclip(noclip)

    if noclip then
        nb.Text="DISABLE NOCLIP"
        nb.BackgroundColor3=Color3.fromRGB(170,0,0)
    else
        nb.Text="ENABLE NOCLIP"
        nb.BackgroundColor3=Color3.fromRGB(0,120,215)
    end
end)

local dragging=false
local ds,sp

tl.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        dragging=true
        ds=i.Position
        sp=fr.Position
    end
end)

tl.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-ds
        fr.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
    end
end)

tl.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        dragging=false
    end
end)

p.CharacterAdded:Connect(function()
    task.wait(0.8)
    if f then sf() end
    if noclip then setNoclip(true) end
end)

print("✅ Fly + Noclip + Minimizar")
