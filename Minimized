local p=game.Players.LocalPlayer
local rs=game:GetService("RunService")
local f=false
local s=1
local mult=15
local bv,bg,con

-- Noclip
local noclip=false
local noclipCon

-- Minimizar
local minimized=false

local controls=require(p:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")):GetControls()

local function sf()
    local c=p.Character
    if not c then return end
    local h=c:FindFirstChild("Humanoid")
    local r=c:FindFirstChild("HumanoidRootPart")
    if not h or not r then return end

    if bv then bv:Destroy() end
    if bg then bg:Destroy() end

    bv=Instance.new("BodyVelocity")
    bv.MaxForce=Vector3.new(1e5,1e5,1e5)
    bv.Velocity=Vector3.new()
    bv.P=3000
    bv.Parent=r

    bg=Instance.new("BodyGyro")
    bg.MaxTorque=Vector3.new(1e5,1e5,1e5)
    bg.P=30000
    bg.D=500
    bg.CFrame=r.CFrame
    bg.Parent=r

    h.PlatformStand=true

    if con then con:Disconnect() end
    con=rs.Heartbeat:Connect(function()
        if not f or not bv then return end
        local cam=workspace.CurrentCamera
        local m=controls:GetMoveVector()
        local dir=(cam.CFrame.RightVector*m.X)+(cam.CFrame.LookVector*-m.Z)
        bv.Velocity=dir*(s*mult)
        bg.CFrame=cam.CFrame
    end)
end

local function stop()
    f=false
    if con then con:Disconnect() end
    if bv then bv:Destroy() bv=nil end
    if bg then bg:Destroy() bg=nil end

    local c=p.Character
    if c and c:FindFirstChild("Humanoid") then
        c.Humanoid.PlatformStand=false
    end
end

-- Noclip
local function setNoclip(state)
    noclip=state

    if noclipCon then
        noclipCon:Disconnect()
        noclipCon=nil
    end

    if noclip then
        noclipCon=rs.Stepped:Connect(function()
            local c=p.Character
            if not c then return end
            for _,v in pairs(c:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide=false
                end
            end
        end)
    else
        local c=p.Character
        if c then
            for _,v in pairs(c:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide=true
                end
            end
        end
    end
end

task.wait(1.5)

